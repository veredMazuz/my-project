<Page x:Class="wpf.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login"
      FlowDirection="RightToLeft"
      Background="Transparent">
    

    <Grid>
        
        <Image x:Name="BackgroundImage" 
               Source="/Images/fish.jpg"
               Stretch="UniformToFill"
               Opacity="0.4">
            <Image.Effect>
                <BlurEffect Radius="20"/>
            </Image.Effect>
        </Image>

        <Rectangle Fill="Black" Opacity="0.5"/>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center" 
                Background="#CC222222" CornerRadius="20" Padding="30" Width="350">

            <StackPanel>
                <TextBlock Text="GOLDY'S" FontSize="40" Foreground="#D4AF37" 
                           HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="שם משתמש" Foreground="White" Margin="0,10,0,5"/>
                <TextBox x:Name="txtUsername" Height="35" Background="#33FFFFFF" 
                         Foreground="White" BorderThickness="0"/>

                <TextBlock Text="סיסמה" Foreground="White" Margin="0,15,0,5"/>

                <Grid>
                    <PasswordBox x:Name="txtCustomerPhone" Height="35" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="5,0,30,0"/>

                    <TextBox x:Name="txtVisiblePhone" Height="35" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Padding="5,0,30,0" Visibility="Collapsed"/>

                    <Button x:Name="btnShowHide" Content="👁" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="30" Foreground="White" Click="btnShowHide_Click"/>
                </Grid>

                <Button Content="התחבר" Margin="0,30,0,0" Height="40" 
                        Background="#D4AF37" Foreground="Black" FontWeight="Bold" Click="Button_Click_1">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
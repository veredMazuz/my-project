<Page x:Class="wpf.MyBasket"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" 
      Title="סל הקניות שלי" 
    FlowDirection="RightToLeft"
      Background="Transparent">

    <Grid>
        <Image x:Name="BackgroundImage" 
               Source="/Images/fish.jpg"
               Stretch="UniformToFill"
               Opacity="0.4">
            <Image.Effect>
                <BlurEffect Radius="25"/>
            </Image.Effect>
        </Image>

        <Rectangle Fill="Black" Opacity="0.6"/>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center" 
                Background="#CC222222" CornerRadius="25" Padding="30" Width="700" Height="550">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="GOLDY'S" FontSize="30" Foreground="#D4AF37" 
                               HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Text="הסל הקניות שלי" FontSize="18" Foreground="White" 
                               HorizontalAlignment="Center" Opacity="0.8"/>
                </StackPanel>

                <ListBox Grid.Row="1" x:Name="lbCart" Background="Transparent" BorderThickness="0" 
                         ScrollViewer.VerticalScrollBarVisibility="Hidden" Margin="0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#33FFFFFF" CornerRadius="12" Margin="0,5" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Product.Name}" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Product.Category}" Foreground="#D4AF37" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='כמות: {0}'}" 
                                               Foreground="White" VerticalAlignment="Center" Margin="30,0"/>

                                    <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat='{}{0} ₪'}" 
                                               Foreground="#D4AF37" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                    <Grid>
                        <StackPanel HorizontalAlignment="Right">
                            <TextBlock Text="סה''כ לתשלום:" Foreground="White" Opacity="0.7" FontSize="14"/>
                            <TextBlock x:Name="lblTotalSum" Text="0.00 ₪" Foreground="#D4AF37" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                            <Button Content="חזרה לתפריט" Click="BackToMenu_Click" Foreground="White" Background="Transparent" 
                                    BorderThickness="0" Margin="0,0,20,0" Cursor="Hand"/>

                            <Button Content="בצע הזמנה" Width="180" Height="45" 
                                    Background="#D4AF37" Foreground="Black" FontWeight="Bold" Click="Checkout_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="15"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>

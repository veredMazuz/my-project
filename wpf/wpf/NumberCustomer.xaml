<Page x:Class="wpf.NumberCustomer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="NumberCustomer"
       FlowDirection="RightToLeft">
<ScrollViewer>
    <StackPanel>
    <TextBlock   Text="מספר העובדים" Margin="10"  Height="30" />
        <TextBlock Margin="10" x:Name="text1"   Height="30" Background="Red" ></TextBlock>
        <Button x:Name="count" Click="count_Click" Content="כמה לקוחות יש??"></Button>
            <Button x:Name="add" Content="הוסף לקוח" Click="add_Click"></Button>
            <ItemsControl x:Name="customers" Margin="10">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="{Binding Name}" Width="200"/>
                        <TextBlock Text="{Binding Phone}" Width="200"/>
                        <TextBlock Text="{Binding Address}" Width="200"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
       

    </StackPanel></ScrollViewer>
</Page>

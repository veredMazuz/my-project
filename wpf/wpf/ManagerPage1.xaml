<Page x:Class="wpf.ManagerPage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ManagerPage1"
      FlowDirection="RightToLeft">

    <Grid>
        <Image x:Name="BackgroundImage" 
               Source="/Images/fish.jpg"
               Stretch="UniformToFill"
               Opacity="0.3">
            <Image.Effect>
                <BlurEffect Radius="30"/>
            </Image.Effect>
        </Image>

        <Rectangle Fill="Black" Opacity="0.7"/>

        <Grid Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#D4AF37"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </StackPanel.Resources>

                <Button x:Name="customers" Content="לקוחות" Click="customers_Click"/>
                <Button x:Name="orders" Content="ניהול הזמנות" Click="orders_Click" />
                <Button x:Name="ContentButton" Content="הודעות" Click="ContentButton_Click"/>
                <Button x:Name="ManageButton" Content="הכנסות" Click="ManageButton_Click"/>
                <Button x:Name="addCatagoria" Content="הוספת קטגוריה" Click="addCatagoria_Click" />
                <Button x:Name="addProduct" Content="הוספת מוצר" Click="addProduct_Click" />
            </StackPanel>

            <Border Grid.Row="1" Grid.ColumnSpan="6" 
                    Background="#33FFFFFF" 
                    CornerRadius="15" 
                    BorderBrush="#D4AF37" 
                    BorderThickness="1" 
                    Margin="0,10,0,0">
                <Frame x:Name="ManagerFrame" NavigationUIVisibility="Hidden"/>
            </Border>
        </Grid>
    </Grid>
</Page>
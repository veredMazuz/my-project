<Page x:Class="wpf.CustomerPage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CustomerPage1"
      FlowDirection="RightToLeft"
      Background="Transparent">

    <Grid>
        <Rectangle Fill="Black" Opacity="0.5"/>

        <Grid Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="myOrder" Grid.Column="4" Grid.Row="0" Content="הזמנות שלי" 
                    Background="#D4AF37" Foreground="Black" FontWeight="Bold" 
                    Height="40" Margin="5" Click="myOrder_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="menu" Grid.Column="5" Grid.Row="0" Content="תפריט" 
                    Background="#D4AF37" Foreground="Black" FontWeight="Bold" 
                    Height="40" Margin="5" Click="menu_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="6" Grid.RowSpan="2" 
                        VerticalAlignment="Center" HorizontalAlignment="Center">

                <Label x:Name="LabelName" Content="שלום וברכה ל..." 
                       FontSize="55" Foreground="#D4AF37" FontWeight="Bold" 
                       HorizontalAlignment="Center">
                    <Label.Effect>
                        <DropShadowEffect BlurRadius="10" Color="Black" ShadowDepth="3"/>
                    </Label.Effect>
                </Label>

                <TextBlock Text="שמחים לראות אותך ב-Goldy's" Foreground="White" 
                           FontSize="20" HorizontalAlignment="Center" Opacity="0.8"/>
            </StackPanel>

            <Frame x:Name="ManagerFrame" NavigationUIVisibility="Hidden" 
                   Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="6" 
                   Margin="0,20,0,0"/>

        </Grid>
    </Grid>
</Page>
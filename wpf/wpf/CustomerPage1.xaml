<Page x:Class="wpf.CustomerPage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CustomerPage1"
       FlowDirection="RightToLeft">

    <Grid Margin="30">



        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>


        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>

        </Grid.RowDefinitions>

        <!-- Header -->


        <Button x:Name="myOrder" Grid.Column="4" Grid.Row="0" Content="הזמנות שלי" BorderBrush="transparent"  Background="Red" Foreground="White"  VerticalAlignment="Top" Click="myOrder_Click" />
        <Button x:Name="menu" Grid.Column="5" Grid.Row="0" Content="תפריט" BorderBrush="transparent" Background="Red" Foreground="White"  VerticalAlignment="Top" Click="menu_Click"  />
        <Label x:Name="LabelName" Content=" שלום וברכה ל" Grid.RowSpan="4" Grid.ColumnSpan="6"  Grid.Row="1" FontSize="48"  Foreground="Red" />


        <!--Frame-->
        <Frame x:Name="ManagerFrame" NavigationUIVisibility="Hidden" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="6"/>

    </Grid>
</Page>

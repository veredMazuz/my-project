<Window x:Class="wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:wpf"
        mc:Ignorable="d"
         Width="800" Height="600"
        Background="#1A1A1A" Title="MainWindow">



    <Grid>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
        <Button x:Name="btnGlobalBack" Content="&#x2190;" Click="btnGlobalBack_Click" FontSize="24" FontWeight="Bold" Background="#D4AF37" Foreground="Black" Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Panel.ZIndex="100">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="20"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
   
       
    
</Window>

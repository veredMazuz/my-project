<Page x:Class="wpf.addCategory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="addCategory"
      FlowDirection="RightToLeft"
      Background="Transparent">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="#CC222222" CornerRadius="20" Padding="40" Width="350" BorderBrush="#D4AF37" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="הוספת קטגוריה חדשה" FontSize="22" Foreground="#D4AF37" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock x:Name="NameProduct" Text="שם הקטגוריה" Foreground="White" Margin="0,0,0,10" FontSize="16"/>
                <TextBox x:Name="txtNameCategory" Height="40" Background="#33FFFFFF" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" FontSize="16" Padding="10,0" Margin="0,0,0,30">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button Content="הוסף קטגוריה למלאי" Height="45" Background="#D4AF37" Foreground="Black" FontWeight="Bold" FontSize="16" Click="Button_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
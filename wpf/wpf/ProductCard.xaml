<UserControl x:Class="wpf.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
              FlowDirection="RightToLeft">
    <StackPanel>
        <TextBlock x:Name="ProductName" Text="{Binding ProductName}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"></TextBlock>
        <TextBlock x:Name="Description" Text="{Binding Description}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"></TextBlock>
        <TextBlock x:Name="Price" Text="{Binding Price}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"></TextBlock>
        <TextBlock x:Name="image" Text="{Binding image}"  FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"></TextBlock>
        <Button x:Name="add" Content="הוסף לסל" Click="addProduct_Click" Background="Red"/>
        
        <!--<Image Source=""-->
    </StackPanel>

</UserControl>

<Page x:Class="wpf.addCustomer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="addCustomer"
       FlowDirection="RightToLeft">

    <StackPanel>

        <Label Content=" תעודת זהות " FontFamily="Arial Black"  />
        <TextBox x:Name="txtCustomerID"/>


        <Label Content=" שם הלקוח " FontFamily="Arial Black"  />
        <TextBox x:Name="txtCustomerName"/>

        <Label Content="טלפון הלקוח" FontFamily="Arial Black" />
        <TextBox x:Name="txtCustomerPhone"/>

        <Label Content="כתובת הלקוח" FontFamily="Arial Black" ></Label>
        <TextBox x:Name="txtCustomerAdrres"/>

        <Button Content="הוסף"  FontFamily="Arial Black" Click="Button_Click"/>
        
       



    </StackPanel>

</Page>
